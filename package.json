{
  "name": "vscode-idl-lang",
  "displayName": "vscode-idl-lang",
  "description": "IDL language syntax highlighting",
  "version": "0.9.8",
  "publisher": "idl-lang-tools",
  "icon": "images/icon.gif",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loongtao/vscode-idl-lang"
  },
  "bugs": "https://github.com/loongtao/vscode-idl-lang/issues",
  "engines": {
    "vscode": "^1.70.0"
  },
  "keywords": [
    "idl",
    "syntax",
    "language"
  ],
  "categories": [
    "Programming Languages"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "main": "./out/main.js",
  "activationEvents": [
    "onLanguage:idl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "idl",
        "aliases": [
          "IDL",
          "idl"
        ],
        "extensions": [
          ".idl"
        ]
      }
    ],
    "grammars": [
      {
        "language": "idl",
        "scopeName": "source.idl",
        "path": "./syntaxes/idl.json"
      }
    ]
  },
  "scripts": {
    "format": "prettier --write ./src/**/*.ts",
    "package": "vsce package",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=out/main.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test-compile": "tsc -p ./",
    "check:versions": "node scripts/check-versions.js"
  },
  "dependencies": {
    "web-tree-sitter": "0.26.7"
  },
  "devDependencies": {
    "@types/node": "^14.11.1",
    "@types/vscode": "^1.70.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.0",
    "prettier": "^2.8.4",
    "typescript": "^4.0.3"
  },
  "prettier": {
    "arrowParens": "avoid",
    "singleQuote": true
  },
  "treeSitterIdlVersion": "v3.17.0"
}
